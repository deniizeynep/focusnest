{
  "expo": {
    "name": "FocusNest",
    "slug": "focusnest",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/focusnest-icon.png",
    "splash": {
      "image": "./assets/images/focusnest-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D12"
    },
    "scheme": "focusnest",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "package": "com.zeynepdeniz.focusnest",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/focusnest-adaptive-icon.png",
        "backgroundColor": "#0D0D12"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
